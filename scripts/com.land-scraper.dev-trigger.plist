<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.land-scraper.dev-trigger</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/dmitrypoluy/dp/my/land-scraper/scripts/trigger-dev-scrape.sh</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>12</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <!-- Run missed jobs after wake from sleep -->
  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/tmp/land-scraper-dev-trigger.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/land-scraper-dev-trigger.log</string>
</dict>
</plist>
