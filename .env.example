# Application
NODE_ENV=development
PORT=3000
APP_NAME=land-scraper

# API key for the /run endpoint (omit to disable auth in dev)
# API_KEY=

# CORS (comma-separated origins or * for all)
CORS_ORIGIN=*

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Telegram bot token (shared — one bot for all modules)
# If omitted, notifications are logged to console instead (dry-run mode)
TELEGRAM_TOKEN=your_bot_token_here

# Land auctions module
SCRAPE_URL=https://gcn.by/zemelnye-uchastki/zemelnye-uchastki-v-sobstvennost/
SCRAPE_CRON=0 8 * * *
TELEGRAM_LAND_AUCTIONS_CHAT_ID=your_land_auctions_chat_id_here

# bid-cars module
BID_CARS_SCRAPE_URL=https://bid.cars/ru/search/results?search-type=filters&status=Active&type=Automobile&make=Volkswagen&model=Atlas&year-from=2023&year-to=2027&auction-type=All&odometer-to=60000&start-code=Run+and+Drive&engine-size-to=2
BID_CARS_SCRAPE_CRON=0 9 * * *
TELEGRAM_BID_CARS_CHAT_ID=your_bid_cars_chat_id_here

# Kufar module
# Override search URLs only if needed (defaults are hardcoded in src/config/constants.ts)
# KUFAR_GARAGES_URL=https://re.kufar.by/l/...
# KUFAR_LAND_URL=https://re.kufar.by/l/...
# KUFAR_HOUSES_URL=https://re.kufar.by/l/...
KUFAR_SCRAPE_CRON=0 9 * * *
TELEGRAM_KUFAR_CHAT_ID=your_kufar_chat_id_here

# realt.by module — plots, garage, cottages (houses), dachi
# Override search URLs only if needed (defaults are hardcoded in src/config/constants.ts)
# REALT_PLOTS_URL=https://realt.by/...
# REALT_GARAGE_URL=https://realt.by/...
# REALT_COTTAGES_URL=https://realt.by/...
# REALT_DACHI_URL=https://realt.by/...
REALT_SCRAPE_CRON=0 9 * * *
TELEGRAM_REALT_CHAT_ID=your_realt_chat_id_here

# mosty-jobs module — job vacancies in Мостовский район (gsz, rabota, joblab, evroopt, crb, kufar, fair)
# Override search URLs only if needed (defaults are hardcoded in src/config/constants.ts)
# MOSTY_JOBS_GSZ_URL=https://gsz.gov.by/registration/vacancy-search/?region=12380&district=14712&sort_by=sort_published_at_desc&paginate_by=50
# MOSTY_JOBS_RABOTA_URL=https://rabota.by/search/vacancy?area=2302
# MOSTY_JOBS_JOBLAB_URL=https://joblab.by/vacancy.php?srcity=54&submit=rss
# MOSTY_JOBS_KUFAR_URL=https://api.kufar.by/search-api/v2/search/rendered-paginated?cat=6010&rgn=3&ar=72&lang=ru&size=30&sort=lst.d
# MOSTY_JOBS_EVROOPT_URL=https://static.erabota.by/api/vacancies?page=1&perPage=50
# MOSTY_JOBS_CRB_URL=https://mostycrb.by/company/vakansii/
# MOSTY_JOBS_FAIRS_URL=https://e-vacancy.by/markets/
MOSTY_JOBS_SCRAPE_CRON=0 9 * * *
TELEGRAM_MOSTY_JOBS_CHAT_ID=your_mosty_jobs_chat_id_here

# bamper.by module — VW Atlas Cross Sport rear bumper (restyle years 2023-2026)
# Behind Cloudflare — driven via Puppeteer. Override the search URL only if needed
# (default is hardcoded in src/config/constants.ts).
# BAMPER_SEARCH_URL=https://bamper.by/zchbu/zapchast_bamper-zadniy/marka_volkswagen/model_atlascrosssport/god_2023-2026/?sort=DATE-DESC
# Channel is intentionally generic ("Atlas parts") — may collect other Atlas parts/sources later.
TELEGRAM_ATLAS_PARTS_CHAT_ID=your_atlas_parts_chat_id_here
