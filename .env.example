# Application
NODE_ENV=development
PORT=3000
APP_NAME=land-scraper

# API key for the /run endpoint (omit to disable auth in dev)
# API_KEY=

# CORS (comma-separated origins or * for all)
CORS_ORIGIN=*

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Telegram bot token (shared — one bot for all modules)
# If omitted, notifications are logged to console instead (dry-run mode)
TELEGRAM_TOKEN=your_bot_token_here

# Land auctions module
SCRAPE_URL=https://gcn.by/zemelnye-uchastki/zemelnye-uchastki-v-sobstvennost/
SCRAPE_CRON=0 8 * * *
TELEGRAM_LAND_AUCTIONS_CHAT_ID=your_land_auctions_chat_id_here

# bid-cars module
BID_CARS_SCRAPE_URL=https://bid.cars/ru/search/results?search-type=filters&status=Active&type=Automobile&make=Volkswagen&model=Atlas&year-from=2023&year-to=2027&auction-type=All&odometer-to=60000&start-code=Run+and+Drive&engine-size-to=2
BID_CARS_SCRAPE_CRON=0 9 * * *
TELEGRAM_BID_CARS_CHAT_ID=your_bid_cars_chat_id_here

# Kufar module — each URL is optional; omit to disable that feed
KUFAR_GARAGES_URL=https://re.kufar.by/l/grodnenskaya-oblast/kupit/garazh?cur=BYR&gbx=b%3A23.725981746227706%2C53.57183301832253%2C23.94948485902068%2C53.75128104662766&size=30
# KUFAR_LAND_URL=https://re.kufar.by/l/grodnenskaya-oblast/kupit/uchastok?cur=BYR&size=30
# KUFAR_HOUSES_URL=https://re.kufar.by/l/grodnenskaya-oblast/kupit/dom?cur=BYR&size=30
KUFAR_SCRAPE_CRON=0 9 * * *
TELEGRAM_KUFAR_CHAT_ID=your_kufar_chat_id_here
